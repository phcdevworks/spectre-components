    "./tooltip": {
      "types": "./dist/tooltip.d.ts",
      "import": "./dist/tooltip.js",
      "require": "./dist/tooltip.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --config tsup.config.ts --watch",
    "verify:app": "vite",
    "typecheck": "tsc --noEmit",
    "release:propose": "node --experimental-strip-types scripts/propose-version.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:exports && npm run check:contract && npm run check:invariants && npm run check:version-sync && npm run check:ecosystem",
    "check:exports": "node --experimental-strip-types scripts/check-exports.ts",
    "check:contract": "node --experimental-strip-types scripts/check-contract.ts",
    "check:invariants": "node --experimental-strip-types scripts/check-invariants.ts",
    "check:version-sync": "node --experimental-strip-types scripts/check-readme-version.ts",
    "check:ecosystem": "spectre-manifest-validate spectre.manifest.json && spectre-manifest-check spectre.manifest.json ."
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": "^5.9 || ^6.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-tokens": "^3.3.1",
    "@phcdevworks/spectre-ui": "^2.7.1",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@phcdevworks/spectre-manifest": "^1.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.64.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
