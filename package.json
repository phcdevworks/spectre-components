{
  "name": "@phcdevworks/spectre-components",
  "version": "1.8.0",
  "description": "@phcdevworks/spectre-components is the Lit-based component layer of the Spectre system. It implements Spectre's design contracts as reusable, accessible, framework-agnostic web components.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-components",
    "web-components",
    "lit",
    "design-system",
    "component-library",
    "framework-agnostic",
    "accessible-components"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-components.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-components/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-components#readme",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "type": "module",
  "packageManager": "npm@12.0.1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js",
      "require": "./dist/input.cjs"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js",
      "require": "./dist/button.cjs"
    },
    "./textarea": {
      "types": "./dist/textarea.d.ts",
      "import": "./dist/textarea.js",
      "require": "./dist/textarea.cjs"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js",
      "require": "./dist/select.cjs"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.ts",
      "import": "./dist/checkbox.js",
      "require": "./dist/checkbox.cjs"
    },
    "./radio": {
      "types": "./dist/radio.d.ts",
      "import": "./dist/radio.js",
      "require": "./dist/radio.cjs"
    },
    "./label": {
      "types": "./dist/label.d.ts",
      "import": "./dist/label.js",
      "require": "./dist/label.cjs"
    },
    "./fieldset": {
      "types": "./dist/fieldset.d.ts",
      "import": "./dist/fieldset.js",
      "require": "./dist/fieldset.cjs"
    },
    "./badge": {
      "types": "./dist/badge.d.ts",
      "import": "./dist/badge.js",
      "require": "./dist/badge.cjs"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "import": "./dist/card.js",
      "require": "./dist/card.cjs"
    },
    "./icon-box": {
      "types": "./dist/icon-box.d.ts",
      "import": "./dist/icon-box.js",
      "require": "./dist/icon-box.cjs"
    },
    "./rating": {
      "types": "./dist/rating.d.ts",
      "import": "./dist/rating.js",
      "require": "./dist/rating.cjs"
    },
    "./testimonial": {
      "types": "./dist/testimonial.d.ts",
      "import": "./dist/testimonial.js",
      "require": "./dist/testimonial.cjs"
    },
    "./alert": {
      "types": "./dist/alert.d.ts",
      "import": "./dist/alert.js",
      "require": "./dist/alert.cjs"
    },
    "./avatar": {
      "types": "./dist/avatar.d.ts",
      "import": "./dist/avatar.js",
      "require": "./dist/avatar.cjs"
    },
    "./spinner": {
      "types": "./dist/spinner.d.ts",
      "import": "./dist/spinner.js",
      "require": "./dist/spinner.cjs"
    },
    "./tag": {
      "types": "./dist/tag.d.ts",
      "import": "./dist/tag.js",
      "require": "./dist/tag.cjs"
    },
    "./pricing-card": {
      "types": "./dist/pricing-card.d.ts",
      "import": "./dist/pricing-card.js",
      "require": "./dist/pricing-card.cjs"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "import": "./dist/container.js",
      "require": "./dist/container.cjs"
    },
    "./grid": {
      "types": "./dist/grid.d.ts",
      "import": "./dist/grid.js",
      "require": "./dist/grid.cjs"
    },
    "./section": {
      "types": "./dist/section.d.ts",
      "import": "./dist/section.js",
      "require": "./dist/section.cjs"
    },
    "./stack": {
      "types": "./dist/stack.d.ts",
      "import": "./dist/stack.js",
      "require": "./dist/stack.cjs"
    },
    "./dropdown": {
      "types": "./dist/dropdown.d.ts",
      "import": "./dist/dropdown.js",
      "require": "./dist/dropdown.cjs"
    },
    "./footer": {
      "types": "./dist/footer.d.ts",
      "import": "./dist/footer.js",
      "require": "./dist/footer.cjs"
    },
    "./modal": {
      "types": "./dist/modal.d.ts",
      "import": "./dist/modal.js",
      "require": "./dist/modal.cjs"
    },
    "./nav": {
      "types": "./dist/nav.d.ts",
      "import": "./dist/nav.js",
      "require": "./dist/nav.cjs"
    },
    "./sidebar": {
      "types": "./dist/sidebar.d.ts",
      "import": "./dist/sidebar.js",
      "require": "./dist/sidebar.cjs"
    },
    "./toast": {
      "types": "./dist/toast.d.ts",
      "import": "./dist/toast.js",
