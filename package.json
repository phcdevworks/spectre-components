{
  "name": "@phcdevworks/spectre-components",
  "version": "1.4.0",
  "description": "@phcdevworks/spectre-components is the Lit-based component layer of the Spectre system for reusable, accessible, framework-agnostic web components.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-components",
    "web-components",
    "lit",
    "design-system",
    "component-library",
    "framework-agnostic",
    "accessible-components"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-components.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-components/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-components#readme",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "type": "module",
  "packageManager": "npm@11.16.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js",
      "require": "./dist/input.cjs"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js",
      "require": "./dist/button.cjs"
    },
    "./textarea": {
      "types": "./dist/textarea.d.ts",
      "import": "./dist/textarea.js",
      "require": "./dist/textarea.cjs"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js",
      "require": "./dist/select.cjs"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.ts",
      "import": "./dist/checkbox.js",
      "require": "./dist/checkbox.cjs"
    },
    "./radio": {
      "types": "./dist/radio.d.ts",
      "import": "./dist/radio.js",
      "require": "./dist/radio.cjs"
    },
    "./label": {
      "types": "./dist/label.d.ts",
      "import": "./dist/label.js",
      "require": "./dist/label.cjs"
    },
    "./fieldset": {
      "types": "./dist/fieldset.d.ts",
      "import": "./dist/fieldset.js",
      "require": "./dist/fieldset.cjs"
    },
    "./badge": {
      "types": "./dist/badge.d.ts",
      "import": "./dist/badge.js",
      "require": "./dist/badge.cjs"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "import": "./dist/card.js",
      "require": "./dist/card.cjs"
    },
    "./icon-box": {
      "types": "./dist/icon-box.d.ts",
      "import": "./dist/icon-box.js",
      "require": "./dist/icon-box.cjs"
    },
    "./rating": {
      "types": "./dist/rating.d.ts",
      "import": "./dist/rating.js",
      "require": "./dist/rating.cjs"
    },
    "./testimonial": {
      "types": "./dist/testimonial.d.ts",
      "import": "./dist/testimonial.js",
      "require": "./dist/testimonial.cjs"
    },
    "./alert": {
      "types": "./dist/alert.d.ts",
      "import": "./dist/alert.js",
      "require": "./dist/alert.cjs"
    },
    "./avatar": {
      "types": "./dist/avatar.d.ts",
      "import": "./dist/avatar.js",
      "require": "./dist/avatar.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --config tsup.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "release:propose": "node --experimental-strip-types scripts/propose-version.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:exports && npm run check:contract && npm run check:invariants && npm run check:ecosystem",
    "check:exports": "node --experimental-strip-types scripts/check-exports.ts",
    "check:contract": "node --experimental-strip-types scripts/check-contract.ts",
    "check:invariants": "node --experimental-strip-types scripts/check-invariants.ts",
    "check:ecosystem": "spectre-manifest-validate spectre.manifest.json && spectre-manifest-check spectre.manifest.json ."
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": "^5.9 || ^6.0"
  },
  "dependencies": {
    "@phcdevworks/spectre-tokens": "^2.9.0",
    "@phcdevworks/spectre-ui": "^1.9.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@phcdevworks/spectre-manifest": "^1.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
